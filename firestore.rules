rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Clients collection - users can only access their own clients
    match /clients/{clientId} {
      allow read, write: if isAuthenticated() &&
                            (resource == null || resource.data.userId == request.auth.uid) &&
                            (!('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid);
    }

    // Jobs collection - users can only access their own jobs
    match /jobs/{jobId} {
      allow read, write: if isAuthenticated() &&
                            (resource == null || resource.data.userId == request.auth.uid) &&
                            (!('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid);
    }

    // Invoices collection - users can only access their own invoices
    match /invoices/{invoiceId} {
      allow read, write: if isAuthenticated() &&
                            (resource == null || resource.data.userId == request.auth.uid) &&
                            (!('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid);
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
